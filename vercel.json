{
  "buildCommand": "npx expo export --platform web && cp web/favicon.png web/favicon.svg web/og-image.png web/og-image.svg dist/",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/((?!.*\\.(?:png|jpg|jpeg|svg|ico|webp|gif|woff2?|ttf|eot|json|txt|xml|pdf)$).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/(.*\\.js|.*\\.css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
